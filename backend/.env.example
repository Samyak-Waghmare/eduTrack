# Server port (defaults to 8080)
PORT=8080

# MongoDB Atlas connection string
MONGO_URI=your-mongodb-connection-string

# Secret used to sign JWT auth tokens
SECRET_KEY=your-jwt-secret

# Allowed CORS origin for the frontend (defaults to http://localhost:5173)
CLIENT_URL=http://localhost:5173

# Cloudinary credentials (used for image/video uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe secret key (optional). When set, paid courses use real Stripe Checkout;
# when unset, checkout falls back to an instant mock purchase for local dev.
STRIPE_SECRET_KEY=sk_test_xxx
